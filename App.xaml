<Application x:Class="TrajectoryCalculator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- 定义所有画刷，初始为暗色 -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#23262e"/>
        <SolidColorBrush x:Key="FrameBackgroundBrush" Color="#2d313a"/>
        <SolidColorBrush x:Key="TextBrush" Color="#eaeef2"/>
        <SolidColorBrush x:Key="EntryBackgroundBrush" Color="#3b404b"/>
        <SolidColorBrush x:Key="EntryForegroundBrush" Color="#f0f4f8"/>
        <SolidColorBrush x:Key="GridRowEvenBrush" Color="#2d313a"/>
        <SolidColorBrush x:Key="GridRowOddBrush" Color="#353a45"/>
        <SolidColorBrush x:Key="GridRowHitBrush" Color="#2a5a3a"/>
        <SolidColorBrush x:Key="ButtonCalcBrush" Color="#3a7bd5"/>
        <SolidColorBrush x:Key="ButtonDeleteBrush" Color="#6b6f7a"/>
        <SolidColorBrush x:Key="ButtonClearBrush" Color="#b54141"/>
        <SolidColorBrush x:Key="ButtonHitBrush" Color="#3a9b5e"/>
        <SolidColorBrush x:Key="ButtonSwitchBrush" Color="#7a5fc0"/>
        <SolidColorBrush x:Key="GridHoverBrush" Color="#4a5060"/>
        <SolidColorBrush x:Key="GridHoverTextBrush" Color="#ffffff"/>
        <sys:Double x:Key="FontSizeNormal">18</sys:Double>
    </Application.Resources>
</Application>